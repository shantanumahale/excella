# ─── PostgreSQL / TimescaleDB ─────────────────────────────
DATABASE_URL=postgresql://excella:excella_dev@postgres:5432/excella
POSTGRES_PASSWORD=excella_dev

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_URL=amqp://excella:excella_dev@rabbitmq:5672/
RABBITMQ_PASSWORD=excella_dev

# ─── Elasticsearch ────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ─── S3 / MinIO ──────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=excella
S3_SECRET_KEY=excella_dev_key
S3_BUCKET=excella-raw
MINIO_PASSWORD=excella_dev_key

# ─── SEC EDGAR ────────────────────────────────────────────
# Required: SEC asks for a User-Agent with your name/email
EDGAR_USER_AGENT=Excella your-email@example.com

# ─── FRED ─────────────────────────────────────────────────
FRED_API_KEY=your_fred_api_key_here

# ─── App ──────────────────────────────────────────────────
LOG_LEVEL=INFO
